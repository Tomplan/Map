# Supabase Backup — Manual / Emergency Use
#
# Automated daily backups now run via GitHub Actions (.github/workflows/backup.yml)
# and are stored on the `backups` git branch.
#
# This file is kept as a fallback in case you need to run backups locally
# (e.g. when working offline before a risky migration).
#
# To run manually:
#   npm run backup:full
#   npm run backup:critical
#
# To reinstall this crontab (if needed):
#   crontab backup-crontab
#
# PATH=/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin
# MAP_DIR=/Users/tom/Documents/GitHub/Map
# 0 10 * * * cd $MAP_DIR && node scripts/backup/backup-full.js --compress >> $MAP_DIR/logs/backup-cron.log 2>&1
